# Copy to `.env` locally. Do not commit `.env`.
# This app uses Firebase only (no Supabase). Remove any EXPO_PUBLIC_SUPABASE_* lines from old setups.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ---------------------------------------------------------------------------
# Google Sign-In (@react-native-google-signin/google-signin + dev build on iOS/Android)
# Copy the Web client ID from Firebase Console > Authentication > Sign-in method > Google
# (Web SDK configuration). Required for ID tokens used with Firebase Auth.
# ---------------------------------------------------------------------------
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# Optional — iOS only if you use a separate iOS OAuth client in Google Cloud Console:
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Optional: Firestore transport (React Native). Default in code = forced long polling.
# EXPO_PUBLIC_FIRESTORE_AUTO_DETECT_LONG_POLL=1
# EXPO_PUBLIC_FIRESTORE_FORCE_LONG_POLL=1

# Optional: same Firebase project region as deployed Cloud Functions (default us-central1).
# EXPO_PUBLIC_FIREBASE_FUNCTIONS_REGION=us-central1

# ---------------------------------------------------------------------------
# FatSecret — NOT used by the Expo app (never add EXPO_PUBLIC_* for FatSecret).
# Keys live only on the server (Firebase Cloud Functions).
#
# • Deployed functions: set secrets, then deploy:
#     firebase functions:secrets:set FATSECRET_CLIENT_ID
#     firebase functions:secrets:set FATSECRET_CLIENT_SECRET
#     firebase deploy --only functions:fatsecretProxy
#
# • Local Functions emulator: copy `functions/.env.example` → `functions/.secret.local`
#   and fill FATSECRET_CLIENT_ID / FATSECRET_CLIENT_SECRET there (not in this root .env).
# ---------------------------------------------------------------------------
