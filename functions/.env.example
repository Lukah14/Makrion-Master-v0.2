# FatSecret — server-side only (Firebase Callable `fatsecretProxy`).
#
# For local emulator: copy this file to `functions/.secret.local`
# and fill in the real values. Firebase emulator reads it automatically.
#
# For production: use Google Secret Manager:
#   firebase functions:secrets:set FATSECRET_CLIENT_ID
#   firebase functions:secrets:set FATSECRET_CLIENT_SECRET
#   firebase deploy --only functions:fatsecretProxy

FATSECRET_CLIENT_ID=your_client_id
FATSECRET_CLIENT_SECRET=your_client_secret
