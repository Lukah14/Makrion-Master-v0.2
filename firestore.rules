rules_version = '2';

// Deploy after edits: firebase deploy --only firestore:rules
// Local changes do not affect production until deployed.

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ──────────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    /** Avoid rule errors when the user profile doc is missing. */
    function isAdmin() {
      return isAuth() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ─── Global curated foods ─────────────────────────────────────────────────
    // Authenticated users can read. Only admins can write.
    match /foods/{foodId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ─── Global exercise library (Activity) ────────────────────────────────────
    // Client path: collection(db, "exercises"). No client writes — seed via Console / Admin SDK.
    match /exercises/{exerciseId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ─── User documents ───────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if isAdmin();

      // Custom foods
      match /myFoods/{foodId} {
        allow read, write: if isOwner(uid);
      }

      // Favorites
      match /favorites/{foodId} {
        allow read, write: if isOwner(uid);
      }

      // Search cache
      match /searchCache/{queryHash} {
        allow read, write: if isOwner(uid);
      }

      // Food logs
      match /foodLogs/{date}/entries/{entryId} {
        allow read, write: if isOwner(uid);
      }

      // Recipes (user-created)
      match /recipes/{recipeId} {
        allow read, write: if isOwner(uid);
      }

      // Saved / bookmarked recipes (FatSecret or own)
      match /savedRecipes/{savedId} {
        allow read, write: if isOwner(uid);
      }

      // Activity logs (legacy path — prefer activities below)
      match /activityLogs/{date}/entries/{activityId} {
        allow read, write: if isOwner(uid);
      }

      // Activity logs: users/{uid}/activities/{activityId} (date field YYYY-MM-DD on each doc)
      // Same owner pattern as foodLogs — only this uid may read/write.
      match /activities/{activityId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Habits
      match /habits/{habitId} {
        allow read, write: if isOwner(uid);
      }

      // Habit completions
      match /habitCompletions/{date}/entries/{completionId} {
        allow read, write: if isOwner(uid);
      }

      // Water logs
      match /waterLogs/{date} {
        allow read, write: if isOwner(uid);
      }

      // Daily steps (manual entry per calendar day; doc id = YYYY-MM-DD)
      match /dailySteps/{dateKey} {
        allow read, write: if isOwner(uid);
      }

      // Progress entries
      match /progressEntries/{entryId} {
        allow read, write: if isOwner(uid);
      }

      // Health / onboarding profile (single doc id e.g. "main")
      match /profile/{profileDocId} {
        allow read, write: if isOwner(uid);
      }
    }

    // ─── Profile documents (new flat structure) ──────────────────────────────
    match /profiles/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if isAdmin();

      match /daily_logs/{dateKey}        { allow read, write: if isOwner(uid); }
      match /food_entries/{entryId}      { allow read, write: if isOwner(uid); }
      match /my_foods/{foodId}           { allow read, write: if isOwner(uid); }
      match /habits/{habitId}            { allow read, write: if isOwner(uid); }
      match /habit_completions/{id}      { allow read, write: if isOwner(uid); }
      match /habit_logs/{id}             { allow read, write: if isOwner(uid); }
      match /habit_checklist_items/{id}  { allow read, write: if isOwner(uid); }
      match /activities/{id}             { allow read, write: if isOwner(uid); }
      match /weight_entries/{id}         { allow read, write: if isOwner(uid); }
      match /memorable_moments/{id}      { allow read, write: if isOwner(uid); }
      // Legacy: `steps` may still exist on daily_logs from older clients; prefer users/{uid}/dailySteps/{dateKey}.
    }

    // ─── Coach-client relation (future expansion) ─────────────────────────────
    match /coaches/{coachId} {
      allow read: if isOwner(coachId) || isAdmin();
      allow write: if isAdmin();

      match /clients/{clientUid} {
        allow read: if isOwner(coachId) || isOwner(clientUid);
        allow write: if isOwner(coachId) || isAdmin();
      }
    }
  }
}
