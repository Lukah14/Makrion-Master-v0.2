{
  "name": "makrion",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "EXPO_NO_TELEMETRY=1 expo start",
    "dev:online": "EXPO_NO_TELEMETRY=1 expo start",
    "dev:offline": "EXPO_NO_TELEMETRY=1 expo start --offline",
    "build:web": "expo export --platform web",
    "lint": "expo lint",
    "seed:exercises": "node scripts/seed-exercises.mjs",
    "seed:exercises:bulk": "node scripts/seed-exercises-from-json.mjs",
    "import:exercises:xlsx": "node scripts/import-exercises-xlsx.mjs",
    "auth:delete-user": "node scripts/delete-auth-user-by-email.mjs",
    "typecheck": "tsc --noEmit",
    "eas:build:apk": "eas build --platform android --profile preview",
    "eas:build:preview:android": "eas build --platform android --profile preview",
    "eas:build:preview:ios": "eas build --platform ios --profile preview",
    "eas:build:preview": "eas build --platform all --profile preview",
    "eas:build:android": "eas build --platform android --profile production",
    "eas:build:ios": "eas build --platform ios --profile production",
    "eas:build:all": "eas build --platform all --profile production",
    "eas:submit:android": "eas submit --platform android --latest --profile production",
    "eas:submit:ios": "eas submit --platform ios --latest --profile production",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo/vector-icons": "^15.0.2",
    "@lucide/lab": "^0.1.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "expo": "^54.0.10",
    "expo-blur": "~15.0.7",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~17.0.8",
    "expo-constants": "~18.0.9",
    "expo-font": "~14.0.8",
    "expo-haptics": "~15.0.7",
    "expo-linear-gradient": "~15.0.7",
    "expo-linking": "~8.0.8",
    "expo-router": "~6.0.8",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "expo-symbols": "~1.0.7",
    "expo-system-ui": "~6.0.7",
    "expo-updates": "~29.0.16",
    "firebase": "^12.12.1",
    "lucide-react-native": "^0.544.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.1.10",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "firebase-admin": "^13.8.0",
    "typescript": "~5.9.2",
    "xlsx": "^0.18.5"
  }
}
